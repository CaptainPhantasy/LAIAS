# =============================================================================
# LAIAS Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Provider API Keys (at least one REQUIRED)
# -----------------------------------------------------------------------------
ZAI_API_KEY=your-zai-api-key-here
OPENAI_API_KEY=sk-your-openai-api-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
OPENROUTER_API_KEY=
PORTKEY_API_KEY=

# -----------------------------------------------------------------------------
# Composio Integration (optional)
# -----------------------------------------------------------------------------
COMPOSIO_API_KEY=
COMPOSIO_BASE_URL=https://api.composio.dev
COMPOSIO_ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# Security (REQUIRED — generate with: python3 -c "import secrets; print(secrets.token_urlsafe(64))")
# -----------------------------------------------------------------------------
JWT_SECRET_KEY=CHANGE-ME-generate-a-64-byte-secret
ORCHESTRATOR_SECRET_KEY=CHANGE-ME-generate-a-48-byte-secret
AUTH_DEV_MODE=true
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
POSTGRES_PASSWORD=CHANGE-ME-use-a-strong-random-password
DATABASE_URL=postgresql+asyncpg://laias:${POSTGRES_PASSWORD}@localhost:5432/laias

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
REDIS_PASSWORD=CHANGE-ME-use-a-strong-random-password
REDIS_URL=redis://:${REDIS_PASSWORD}@localhost:6379/0

# -----------------------------------------------------------------------------
# Service Configuration
# -----------------------------------------------------------------------------
DEFAULT_LLM_PROVIDER=zai
DEFAULT_MODEL=glm-4.7-flash
LOG_LEVEL=INFO
ENVIRONMENT=development

# -----------------------------------------------------------------------------
# Stack Auth (OAuth — REQUIRED for frontend authentication)
# Create a project at https://app.stack-auth.com to get these values
# -----------------------------------------------------------------------------
NEXT_PUBLIC_STACK_PROJECT_ID=your-stack-project-id
STACK_SECRET_SERVER_KEY=your-stack-secret-server-key

# -----------------------------------------------------------------------------
# Frontend URLs (optional — override for non-default ports or reverse proxy)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_AGENT_GENERATOR_URL=http://localhost:4521
# NEXT_PUBLIC_DOCKER_ORCHESTRATOR_URL=http://localhost:4522
# NEXT_PUBLIC_CONTROL_ROOM_URL=http://localhost:4528

# -----------------------------------------------------------------------------
# Network Ports (optional — override defaults)
# -----------------------------------------------------------------------------
# Bind to 127.0.0.1 to restrict to localhost only (recommended)
# POSTGRES_PORT=127.0.0.1:5432
# REDIS_PORT=127.0.0.1:6379
