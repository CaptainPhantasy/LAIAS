# =============================================================================
# LAIAS Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Provider API Keys (REQUIRED)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
POSTGRES_PASSWORD=laias_dev_password
DATABASE_URL=postgresql+asyncpg://laias:${POSTGRES_PASSWORD}@localhost:5432/laias

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Service Configuration (Optional)
# -----------------------------------------------------------------------------
# Default LLM provider: openai or anthropic
DEFAULT_LLM_PROVIDER=openai

# Default model for generation
DEFAULT_MODEL=gpt-4o

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Authentication (REQUIRED for production)
# -----------------------------------------------------------------------------
# Set to false in production to require JWT auth
AUTH_DEV_MODE=true

# JWT secret key - MUST be changed in production
JWT_SECRET_KEY=your-secure-secret-key-change-in-production

# Token expiration
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
