# =============================================================================
# Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# -----------------------------------------------------------------------------
# LLM Provider Configuration
# -----------------------------------------------------------------------------

# Provider: openai, anthropic, ollama, groq
LLM_PROVIDER=openai

# Model to use
LLM_MODEL=gpt-4o

# API Key (required for most providers)
OPENAI_API_KEY=sk-your-key-here
# ANTHROPIC_API_KEY=your-key-here
# GROQ_API_KEY=your-key-here

# Base URL (for OpenAI-compatible APIs, Ollama, etc.)
# LLM_BASE_URL=http://localhost:11434/v1

# -----------------------------------------------------------------------------
# Research Configuration
# -----------------------------------------------------------------------------

# Output directory for research documents
OUTPUT_DIR=./research_output

# Research topic (optional - will prompt if not set)
# RESEARCH_TOPIC="Your topic here"
